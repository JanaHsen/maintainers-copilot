# Vault dev-mode root token. Generate any string; required for local dev only.
VAULT_DEV_ROOT_TOKEN_ID=

# Port mappings (host-side; container-side ports are fixed in docker-compose.yml)
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
VAULT_PORT=8200
PHOENIX_PORT=6006
MODEL_SERVER_PORT=8001

# Classifier artifact identifiers consumed by the model server at boot.
# MODEL_RUN_ID -> artifacts/classifier/distilbert/{MODEL_RUN_ID}/ in MinIO.
# DATASET_RUN_ID -> processed/pandas/{DATASET_RUN_ID}/train.parquet (used to
# recompute and verify the training_data_hash recorded in model_card.json).
MODEL_RUN_ID=20260520T193153Z
DATASET_RUN_ID=20260519T133455Z

# RAG corpus identifier consumed by the api at boot. The api refuses to
# boot if this is unset or if rag_chunks has no rows for this value
# (Rule 4 — see app/main.py::_verify_rag_corpus).
RAG_CORPUS_RUN_ID=

# First-admin bootstrap credentials. The admin-bootstrap docker service
# reads these from Vault at first boot and creates one admin user if no
# admin exists yet (no-op on subsequent runs). MUST be changed before any
# real deploy — the placeholders below are visible in version control.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme-please
